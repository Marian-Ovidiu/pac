# Sensitive/local config
!wp-config.php
.env
.env.*

# IDE / OS
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
wp-content/debug.log

# Dependencies
node_modules/
vendor/
wp-content/plugins/*/vendor/
# Rank Math SEO: includi vendor in repo (altrimenti deploy senza autoload.php)
!wp-content/plugins/seo-by-rank-math/
!wp-content/plugins/seo-by-rank-math/vendor/
!wp-content/plugins/seo-by-rank-math/vendor/**
wp-content/themes/my_structure/node_modules/
wp-content/themes/my_structure/vendor/

# WordPress runtime/generated content
wp-content/cache/
wp-content/uploads/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/wc-logs/
wp-content/ewww/
wp-content/mu-plugins/

# Backups / exports
*.sql
*.zip
*.tar.gz
*.bak
*.bk

# Keep custom theme sources, ignore generated artifacts
!wp-content/themes/
!wp-content/themes/my_structure/
!wp-content/themes/my_structure/**
wp-content/themes/my_structure/public/
wp-content/themes/my_structure/resources/cache/
wp-content/themes/my_structure/node_modules/
wp-content/themes/my_structure/vendor/

# Keep plugin/theme source, ignore known unwanted plugin copies
!wp-content/plugins/
wp-content/plugins/wp-mail-smtp/
